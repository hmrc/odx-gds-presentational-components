{
  "name": "hmrc-gds-react-components",
  "version": "0.0.11",
  "private": false,
  "description": "Collection of React Components that fulfil the GDS Specification for use in applications",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*/index.js"
  },
  "scripts": {
    "clean": "rm -Rf dist",
    "clean:ps": "@powershell if (Test-Path ./dist) {Remove-Item ./dist -Recurse -Force}",
    "test": "npm run lint:fix  & jest --coverage",
    "test:update": "jest --coverage -u",
    "storybook": "storybook dev -p 6006",
    "storybook:debug:webpack": "storybook dev -p 6006 --debug-webpack",
    "build-storybook": "storybook build",
    "build:dev": "webpack --mode=development",
    "pipeline:lint": "echo \"linting...\" && npm run _internal-install-sdk && npx eslint \"src/**\"",
    "_internal-install-sdk": "echo \"installing...\" && npm install --loglevel notice",
    "lint": "ts-standard -p ./tsconfig.eslint.json",
    "lint:fix": "ts-standard src --fix",
    "build:prod": "npm run clean && npm run test && rollup -c ",
    "build:prod:ps": "npm run clean:ps && npm run test && rollup -c ",
    "build:prod:dirty": "npm run test && rollup -c"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@storybook/addon-essentials": "^7.6.4",
    "@storybook/addon-interactions": "^7.6.4",
    "@storybook/addon-links": "^7.6.4",
    "@storybook/addon-onboarding": "^1.0.9",
    "@storybook/addon-styling-webpack": "^0.0.5",
    "@storybook/blocks": "^7.6.4",
    "@storybook/react": "^7.6.4",
    "@storybook/react-webpack5": "^7.6.4",
    "@storybook/test": "^7.6.4",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.2.39",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "enzyme": "^3.11.0",
    "govuk-frontend": "^5.8.0",
    "hmrc-frontend": "^6.1.0",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-stare": "^2.5.2",
    "npm-dts-webpack-plugin": "^1.3.12",
    "prop-types": "^15.8.1",
    "react-test-renderer": "^18.2.0",
    "rollup": "^4.9.6",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-generate-package-json": "^3.2.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-sass": "^1.12.21",
    "rollup-plugin-scss": "^4.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "sass": "^1.72.0",
    "sass-loader": "^13.3.2",
    "standard": "^17.1.0",
    "storybook": "^7.6.4",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-standard": "^12.0.2",
    "webpack-cli": "^5.1.4",
    "webpack-react-component-name": "^5.0.5"
  },
  "dependencies": {
    "@x-govuk/govuk-prototype-components": "^5.0.2",
    "focus-trap-react": "^10.2.3"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "ts-standard": {
    "ignore": [
      "dist",
      "src/**/*stories.*",
      "rollup.config_old.mjs",
      "*.config.*",
      "__mocks__/**/*"
    ]
  }
}
