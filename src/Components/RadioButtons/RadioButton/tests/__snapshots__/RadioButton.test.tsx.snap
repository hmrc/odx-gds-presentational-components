exports[`Default Checked Radio button Snapshot 1`] = `
<div
  className="govuk-radios__item"
>
  <input
    className="govuk-radios__input"
    defaultChecked={true}
    id="radio-button"
    name="radio-button"
    type="radio"
    value="yes"
  />
  <label
    className="govuk-label govuk-radios__label"
    htmlFor="radio-button"
  >
    Yes
  </label>
</div>
`;

